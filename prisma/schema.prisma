generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model diary_entries {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  season_id          String              @db.Uuid
  farm_id            String              @db.Uuid
  actor_user_id      String              @db.Uuid
  event_type         diary_event_type
  event_date         DateTime            @db.Date
  server_timestamp   DateTime            @default(now()) @db.Timestamp(6)
  description        String?
  extra_data         Json?
  created_at         DateTime            @default(now()) @db.Timestamp(6)
  diary_attachments  diary_attachments[]
  users              users               @relation(fields: [actor_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_diary_actor")
  farms              farms               @relation(fields: [farm_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_diary_farm")
  seasons            seasons             @relation(fields: [season_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_diary_season")

  @@index([season_id, event_date], map: "idx_diary_season_event_date")
  @@index([season_id, server_timestamp], map: "idx_diary_season_server_ts")
}

model diary_attachments {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  diary_entry_id  String        @db.Uuid
  file_url        String
  mime_type       String?       @db.VarChar(120)
  sort_order      Int           @default(0)
  meta            Json?
  created_at      DateTime      @default(now()) @db.Timestamp(6)
  diary_entries   diary_entries @relation(fields: [diary_entry_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_diary_attachments_entry")

  @@index([diary_entry_id, sort_order], map: "idx_diary_attachments_entry_sort")
}

model forum_posts {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  author_user_id String             @db.Uuid
  title          String             @db.VarChar(220)
  content        String
  status         forum_post_status  @default(active)
  created_at     DateTime           @default(now()) @db.Timestamp(6)
  updated_at     DateTime           @default(now()) @db.Timestamp(6)
  forum_comments forum_comments[]
  forum_post_images forum_post_images[]
  forum_post_labels forum_post_labels[]
  users          users              @relation(fields: [author_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_forum_posts_author")

  @@index([author_user_id, created_at], map: "idx_forum_posts_author_created")
  @@index([status, created_at], map: "idx_forum_posts_status_created")
}

model forum_post_images {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  post_id    String      @db.Uuid
  object_key String      @db.VarChar(2048)
  file_url   String
  sort_order Int         @default(0)
  created_at DateTime    @default(now()) @db.Timestamp(6)
  forum_posts forum_posts @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_forum_post_images_post")

  @@index([post_id, sort_order], map: "idx_forum_post_images_post_sort")
}

model forum_comments {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  post_id        String      @db.Uuid
  author_user_id String      @db.Uuid
  content        String
  created_at     DateTime    @default(now()) @db.Timestamp(6)
  updated_at     DateTime    @default(now()) @db.Timestamp(6)
  forum_posts    forum_posts @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_forum_comments_post")
  users          users       @relation(fields: [author_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_forum_comments_author")

  @@index([post_id, created_at], map: "idx_forum_comments_post_created")
  @@index([author_user_id, created_at], map: "idx_forum_comments_author_created")
}

model forum_post_labels {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  post_id    String      @db.Uuid
  label      String      @db.VarChar(80)
  created_at DateTime    @default(now()) @db.Timestamp(6)
  forum_posts forum_posts @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_forum_labels_post")

  @@unique([post_id, label], map: "uq_forum_post_label")
  @@index([label, created_at], map: "idx_forum_labels_label_created")
}

model farms {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  owner_user_id String          @db.Uuid
  name          String          @db.VarChar(180)
  area_ha       Decimal?        @db.Decimal(10, 2)
  crop_main     String?         @db.VarChar(120)
  province      String?         @db.VarChar(100)
  district      String?         @db.VarChar(100)
  ward          String?         @db.VarChar(100)
  address        String?
  latitude       Decimal?        @db.Decimal(10, 7)
  longitude      Decimal?        @db.Decimal(10, 7)
  in_cooperative Boolean         @default(false)
  created_at     DateTime        @default(now()) @db.Timestamp(6)
  updated_at     DateTime        @default(now()) @db.Timestamp(6)
  cooperative_members cooperative_members[]
  diary_entries diary_entries[]
  users         users           @relation(fields: [owner_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_farms_owner")
  seasons       seasons[]
  shops         shops?
}

model cooperative_members {
  id                  String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cooperative_user_id String                    @db.Uuid
  farmer_user_id      String                    @db.Uuid
  farm_id             String                    @db.Uuid
  status              cooperative_member_status @default(pending)
  requested_by        String?                   @db.Uuid
  verified_by         String?                   @db.Uuid
  verified_at         DateTime?                 @db.Timestamp(6)
  note                String?
  created_at          DateTime                  @default(now()) @db.Timestamp(6)
  updated_at          DateTime                  @default(now()) @db.Timestamp(6)
  farms               farms                     @relation(fields: [farm_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_coop_members_farm")
  cooperative_user    users                     @relation("cooperative_user_members", fields: [cooperative_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_coop_members_cooperative_user")
  farmer_user         users                     @relation("farmer_user_members", fields: [farmer_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_coop_members_farmer_user")
  requester           users?                    @relation("requested_by_members", fields: [requested_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_coop_members_requested_by")
  verifier            users?                    @relation("verified_by_members", fields: [verified_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_coop_members_verified_by")

  @@index([farm_id, status], map: "idx_coop_members_farm_status")
  @@index([cooperative_user_id, status], map: "idx_coop_members_cooperative_status")
  @@index([farmer_user_id, status], map: "idx_coop_members_farmer_status")
}

model order_items {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id   String   @db.Uuid
  product_id String   @db.Uuid
  qty        Decimal  @db.Decimal(10, 2)
  unit_price Decimal  @db.Decimal(12, 2)
  line_total Decimal  @db.Decimal(12, 2)
  orders     orders   @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_order_items_order")
  products   products @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_order_items_product")

  @@index([order_id, product_id], map: "idx_order_items_order_product")
}

model orders {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  buyer_user_id    String         @db.Uuid
  shop_id          String         @db.Uuid
  status           order_status   @default(pending)
  payment_method   payment_method @default(cod)
  payment_status   payment_status @default(pending)
  total_amount     Decimal        @default(0) @db.Decimal(12, 2)
  shipping_name    String?        @db.VarChar(120)
  shipping_phone   String?        @db.VarChar(20)
  shipping_address String?
  note             String?
  created_at       DateTime       @default(now()) @db.Timestamp(6)
  updated_at       DateTime       @default(now()) @db.Timestamp(6)
  order_items      order_items[]
  users            users          @relation(fields: [buyer_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_orders_buyer")
  shops            shops          @relation(fields: [shop_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_orders_shop")
  shop_reviews     shop_reviews[]

  @@index([buyer_user_id, status, created_at], map: "idx_orders_buyer_status_created_at")
  @@index([shop_id, status, created_at], map: "idx_orders_shop_status_created_at")
}

model products {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shop_id     String        @db.Uuid
  season_id   String?       @db.Uuid
  name        String        @db.VarChar(180)
  description String?
  price       Decimal       @db.Decimal(12, 2)
  unit        String?       @default("kg") @db.VarChar(20)
  stock_qty   Decimal?      @default(0) @db.Decimal(10, 2)
  image_url   String?       @db.VarChar(512)
  is_active   Boolean       @default(true)
  created_at  DateTime      @default(now()) @db.Timestamp(6)
  updated_at  DateTime      @default(now()) @db.Timestamp(6)
  sale_unit_id String?       @unique @db.Uuid
  order_items  order_items[]
  seasons      seasons?      @relation(fields: [season_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_products_season")
  shops        shops         @relation(fields: [shop_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_products_shop")
  sale_unit    sale_units?   @relation(fields: [sale_unit_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_products_sale_unit")

  @@index([shop_id, is_active], map: "idx_products_shop_active")
}

model refresh_tokens {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  token_hash String    @unique @db.VarChar(255)
  device_id  String    @db.VarChar(120)
  expires_at DateTime  @db.Timestamp(6)
  revoked_at DateTime? @db.Timestamp(6)
  created_at DateTime  @default(now()) @db.Timestamp(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_refresh_tokens_user")

  @@index([user_id, device_id], map: "idx_refresh_tokens_user_device")
  @@index([user_id, revoked_at], map: "idx_refresh_tokens_user_revoked_at")
}

model sale_units {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  season_id   String           @db.Uuid
  code        String           @unique @db.VarChar(80)
  quantity    Decimal          @db.Decimal(10, 2)
  unit        String           @default("kg") @db.VarChar(20)
  qr_token    String           @unique @db.VarChar(120)
  qr_url      String
  short_code  String?          @unique @db.VarChar(30)
  status      sale_unit_status @default(active)
  created_at  DateTime         @default(now()) @db.Timestamp(6)
  seasons     seasons          @relation(fields: [season_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_sale_units_season")
  trace_scans trace_scans[]
  product     products?

  @@index([season_id, status], map: "idx_sale_units_season_status")
}

model season_anchors {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  season_id     String        @db.Uuid
  checkpoint_no Int
  checkpoint_type String      @default("manual") @db.VarChar(30)
  is_final      Boolean       @default(false)
  payload_range Json?
  hash_algo     String        @default("SHA-256") @db.VarChar(20)
  data_hash     String        @db.VarChar(130)
  chain_network String?       @default("db_only") @db.VarChar(50)
  tx_hash       String?       @db.VarChar(120)
  tx_url        String?
  status        anchor_status @default(pending)
  anchored_at   DateTime?     @db.Timestamp(6)
  anchor_meta   Json?
  created_at    DateTime      @default(now()) @db.Timestamp(6)
  seasons       seasons       @relation(fields: [season_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_anchor_season")

  @@unique([season_id, checkpoint_no], map: "uq_season_anchor_checkpoint")
  @@index([season_id, created_at], map: "idx_season_anchors_season_created_at")
}

model seasons {
  id                 String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  farm_id            String          @db.Uuid
  code               String          @unique @db.VarChar(80)
  crop_name          String          @db.VarChar(120)
  start_date         DateTime        @db.Date
  harvest_start_date DateTime?       @db.Date
  harvest_end_date   DateTime?       @db.Date
  estimated_yield    Decimal?        @db.Decimal(12, 2)
  actual_yield       Decimal?        @db.Decimal(12, 2)
  yield_unit         String?         @default("kg") @db.VarChar(20)
  status             season_status   @default(draft)
  sealed_at          DateTime?       @db.Timestamp(6)
  created_by         String          @db.Uuid
  created_at         DateTime        @default(now()) @db.Timestamp(6)
  updated_at         DateTime        @default(now()) @db.Timestamp(6)
  diary_entries      diary_entries[]
  products           products[]
  sale_units         sale_units[]
  season_anchors     season_anchors[]
  users              users           @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_seasons_created_by")
  farms              farms           @relation(fields: [farm_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_seasons_farm")

  @@index([farm_id, status], map: "idx_seasons_farm_status")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model shop_reviews {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id              String   @db.Uuid
  order_id             String   @db.Uuid
  shop_id              String   @db.Uuid
  rating               Int
  comment              String?
  is_verified_purchase Boolean  @default(true)
  review_meta          Json?
  created_at           DateTime @default(now()) @db.Timestamp(6)
  updated_at           DateTime @default(now()) @db.Timestamp(6)
  orders               orders   @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_reviews_order")
  shops                shops    @relation(fields: [shop_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_reviews_shop")
  users                users    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_reviews_user")

  @@unique([user_id, order_id, shop_id], map: "uq_shop_reviews_user_order_shop")
  @@index([shop_id, created_at], map: "idx_shop_reviews_shop_created_at")
}

model shops {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  farm_id        String         @unique @db.Uuid
  name           String         @db.VarChar(180)
  description    String?
  avatar_url     String?        @db.VarChar(2048)
  status         String         @default("open") @db.VarChar(20)
  is_verified    Boolean        @default(false)
  certifications Json?
  created_at     DateTime       @default(now()) @db.Timestamp(6)
  updated_at     DateTime       @default(now()) @db.Timestamp(6)
  orders         orders[]
  products       products[]
  shop_reviews   shop_reviews[]
  farms          farms          @relation(fields: [farm_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_shops_farm")
}

model trace_scans {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sale_unit_id  String     @db.Uuid
  scanned_at    DateTime   @default(now()) @db.Timestamp(6)
  ip_address    String?    @db.VarChar(64)
  user_agent    String?
  geo_lat       Decimal?   @db.Decimal(10, 7)
  geo_lng       Decimal?   @db.Decimal(10, 7)
  result        String     @default("ok") @db.VarChar(20)
  abnormal_flag Boolean    @default(false)
  scan_meta     Json?
  sale_units    sale_units @relation(fields: [sale_unit_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_trace_sale_unit")

  @@index([sale_unit_id, scanned_at], map: "idx_trace_scans_sale_unit_scanned_at")
}

/// Hội thoại 1-1 giữa hai user. Luôn có participant_1_id < participant_2_id (UUID) — một thread / cặp.
model chat_conversations {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  participant_1_id String           @db.Uuid
  participant_2_id String           @db.Uuid
  created_at       DateTime         @default(now()) @db.Timestamp(6)
  updated_at       DateTime         @default(now()) @db.Timestamp(6)
  participant_1    users            @relation("chat_participant_1", fields: [participant_1_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_chat_conv_p1")
  participant_2    users            @relation("chat_participant_2", fields: [participant_2_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_chat_conv_p2")
  messages         chat_messages[]

  @@unique([participant_1_id, participant_2_id], map: "uq_chat_conv_participants")
  @@index([participant_1_id, updated_at], map: "idx_chat_conv_p1_updated")
  @@index([participant_2_id, updated_at], map: "idx_chat_conv_p2_updated")
}

model chat_messages {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id String             @db.Uuid
  sender_user_id  String             @db.Uuid
  content         String
  created_at      DateTime           @default(now()) @db.Timestamp(6)
  conversation    chat_conversations @relation(fields: [conversation_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_chat_msg_conv")
  sender          users              @relation(fields: [sender_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_chat_msg_sender")

  @@index([conversation_id, created_at], map: "idx_chat_msg_conv_created")
}

model users {
  id                   String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone                String           @unique @db.VarChar(20)
  email                String?          @unique @db.VarChar(255)
  forum_comments       forum_comments[]
  forum_posts          forum_posts[]
  password_hash        String?          @db.VarChar(255)
  full_name            String           @db.VarChar(120)
  avatar_url           String?          @db.VarChar(2048)
  role                 user_role        @default(farmer)
  status               account_status   @default(active)
  reset_password_token String?          @db.VarChar(255)
  created_at           DateTime         @default(now()) @db.Timestamp(6)
  updated_at           DateTime         @default(now()) @db.Timestamp(6)
  diary_entries        diary_entries[]
  cooperative_members_as_cooperative cooperative_members[] @relation("cooperative_user_members")
  cooperative_members_as_farmer      cooperative_members[] @relation("farmer_user_members")
  cooperative_members_as_requester   cooperative_members[] @relation("requested_by_members")
  cooperative_members_as_verifier    cooperative_members[] @relation("verified_by_members")
  farms                farms[]
  orders               orders[]
  refresh_tokens       refresh_tokens[]
  seasons              seasons[]
  shop_reviews         shop_reviews[]
  chat_conversations_as_p1 chat_conversations[] @relation("chat_participant_1")
  chat_conversations_as_p2 chat_conversations[] @relation("chat_participant_2")
  chat_messages                  chat_messages[]
}

enum account_status {
  active
  pending
  suspended
}

enum anchor_status {
  pending
  anchored
  failed
}

enum diary_event_type {
  land_prep
  sowing
  fertilizing
  pesticide
  irrigation
  harvesting
  packing
  inspection
  other
}

enum forum_post_status {
  active
  hidden
  locked
}

enum order_status {
  pending
  confirmed
  shipping
  delivered
  cancelled
}

enum payment_method {
  cod
  vnpay
  payos
}

enum payment_status {
  pending
  paid
  failed
  refunded
}

enum cooperative_member_status {
  pending
  approved
  rejected
  removed
}

enum sale_unit_status {
  active
  sold
  disabled
}

enum season_status {
  draft 
  ready_to_anchor
  anchored
  amended
  failed
}

enum user_role {
  consumer
  farmer
  cooperative
  admin
}
