DATABASE_URL="postgresql://<user>:<password>@<host>:5432/<db_name>?schema=public"
PORT=8000
NODE_ENV=development

JWT_ACCESS_TOKEN_SECRET=""
JWT_ACCESS_TOKEN_EXPIRES_IN="1h"
JWT_REFRESH_TOKEN_SECRET=""
JWT_REFRESH_TOKEN_EXPIRES_IN="7d"
JWT_RESET_PASSWORD_TOKEN_SECRET=""
JWT_RESET_PASSWORD_TOKEN_EXPIRES_IN="1h"
PASSWORD_HASH_SECRET=""

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Chuoi Xanh Viet <no-reply@example.com>"
# Link reset mật khẩu — trùng host với FE người dùng mở (VPS :3000)
CLIENT_RESET_PASSWORD_URL="http://localhost:3000/reset-password"

# Frontend cổng 3000: CORS + Socket (xem `src/config/cors.ts`)
# - `FRONTEND_URLS`: nhiều origin, cách nhau bằng dấu phẩy (local + VPS).
# - `FRONTEND_URL`: tuỳ chọn, một URL thêm vào danh sách.
# - Nếu để trống cả hai → code dùng mặc định localhost:3000 + 178.128.98.214:3000.
FRONTEND_URL=
FRONTEND_URLS="http://localhost:3000,http://178.128.98.214:3000"

# URL app public (QR lô, deep-link, PayOS return/cancel) — nên là URL FE thật trên mạng
PUBLIC_APP_URL="http://localhost:3000"

# PayOS — lấy từ PayOS merchant (Client ID / API Key / Checksum Key)
PAYOS_CLIENT_ID=""
PAYOS_API_KEY=""
PAYOS_CHECKSUM_KEY=""
# Thời gian sống link thanh toán PayOS (phút, mặc định 15; tối đa 1440)
PAYOS_LINK_TTL_MINUTES=15

# (Deprecated) Code không đọc; whitelist CORS do FRONTEND_URLS / FRONTEND_URL + cors.ts.
CORS_ORIGIN="http://localhost:3000,http://localhost:8000"

# Image upload (forum, inspection attachments, …) — BE proxy tới worker
# Bắt buộc trên server nếu dùng POST /upload. Local: copy cùng giá trị như máy dev.
IMAGE_WORKER_SERVICE_API=""
IMAGE_WORKER_SERVICE_KEY=""
# Document upload (chứng chỉ VietGAP, PDF/ảnh scan, …) — POST /upload/documents → proxy worker
# Có thể trùng key với IMAGE_WORKER_SERVICE_KEY; nếu để trống BE sẽ fallback sang IMAGE_WORKER_SERVICE_KEY
DOCUMENT_WORKER_SERVICE_API=""
DOCUMENT_WORKER_SERVICE_KEY=""

# Gemini (AI features) — comma-separated API keys optional for rotation
GEMINI_API_KEYS=""
GEMINI_MODEL="gemini-1.5-flash-lite-preview"
GEMINI_MAX_RETRIES=5
GEMINI_TEMPERATURE=0.3

# Blockchain anchoring — Sepolia testnet
# Hướng dẫn: xem contracts/DiaryAnchor.sol + deploy qua Remix IDE (remix.ethereum.org)
SEPOLIA_RPC_URL=""
ANCHOR_WALLET_PRIVATE_KEY=""
ANCHOR_CONTRACT_ADDRESS=""

# OpenAI (tuỳ chọn) — dùng cho các tính năng AI bổ trợ
OPENAI_API_KEY=""

# Zalo Official Account — gửi tin nhắn cho nông dân (sau khi họ quan tâm OA và lưu zaloUserId qua PATCH /auth/me)
# Lấy App ID, Secret, Refresh token tại developers.zalo.me → Ứng dụng của tôi → OA.
ZALO_OA_ENABLED=0
ZALO_OA_APP_ID=""
ZALO_OA_APP_SECRET=""
ZALO_OA_REFRESH_TOKEN=""

# Telegram — thông báo nông dân (Bot API). Webhook: POST https://<host>/v1/api/integrations/telegram/webhook
# Tạo bot: @BotFather → /newbot → lấy token. username bot (không @) lấy từ BotFather hoặc t.me/<username>
TELEGRAM_BOT_TOKEN=""
# Ví dụ: chuoi_xanh_notify (không gồm @)
TELEGRAM_BOT_USERNAME=""
# Bật gửi push khi có thông báo in-app (cần user đã liên kết qua deep link + Start)
TELEGRAM_NOTIFICATIONS_ENABLED=0
# Tuỳ chọn: khi đăng ký webhook với secret_token, Telegram gửi header X-Telegram-Bot-Api-Secret-Token
TELEGRAM_WEBHOOK_SECRET=""
